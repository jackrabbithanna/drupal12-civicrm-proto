# Ignore directories generated by Composer
/drush/contrib/
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/
/web/recipes/*
!/web/recipes/custom/
!/web/recipes/custom/**
/recipes/

/console/

# Ignore sensitive information
/web/sites/*/settings.local.php
/web/sites/*/civicrm/extensions/contrib/*
!web/sites/*/civicrm/extensions/contrib/.gitkeep
/web/sites/*/civicrm/extensions/cache/*
**/civicrm/templates_c/*
**/civicrm/upload/*
**/civicrm/upload/.htaccess
**/civicrm/ConfigAndLog/*
/web/sites/default/php/


# Ignore SimpleTest multi-site environment.
/web/sites/simpletest

# Ignore files generated by PhpStorm
/.idea/

# Ignore .env files as they are personal
/.env

# Ignore mounts
web/sites/*/files
tmp
/private
.drush
drush-backups
.console
/.editorconfig
/.gitattributes
.twig-cs-fixer.cache

# Ignore Mac's DS Store
.DS_Store

# Ignore node modules
node_modules

# Ignore auto-generated files
web/themes/custom/*/*.min.css
web/themes/custom/*/*.map

# Ignore Subtheme components and generated files
web/themes/custom/*/bower_components
#web/themes/custom/*/dist

# Ignore database files
#*.sql
*.sql.gz

# Ansible files.
*.retry
.galaxy_install_info

# Vagrant files.
.vagrant/
vagrant_ansible_inventory_default

# Drupal VM specific files.
local.config.yml
local.behat.yml
Vagrantfile.local
/config.yml
/docker-compose.yml
/drupal.make.yml
/drupal/

# DDev files
.ddev/traefik
.ddev/.env.temp

# Upsun files
!/.upsun/local/project.yaml

# Claude files
.claude/settings.local.json
.claude/commands/contrib/
